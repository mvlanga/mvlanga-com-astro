{
  "extends": "astro/tsconfigs/strictest",
  "include": [
    "src/**/*.astro",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "jsxImportSource": "react",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "strictNullChecks": true,
    "allowJs": true,
    "exactOptionalPropertyTypes": false,
    "types": [
      "vitest/globals"
    ]
  }
}
