		"vue": "^3.5.30"
	},
	"devDependencies": {
		"@astrojs/check": "0.9.8",
		"@astrojs/db": "^0.20.1",
		"@astrojs/mdx": "5.0.3",
		"@astrojs/netlify": "^7.0.6",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.2",
		"@astrojs/vue": "6.0.1",
		"@axe-core/playwright": "^4.11.1",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.2",
		"@typescript-eslint/parser": "^8.58.0",
		"astro": "6.1.3",
		"eslint": "^10.2.0",
