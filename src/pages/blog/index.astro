---
export const prerender = true;

import RssIcon from "@/assets/icons/rss.svg";
import VBlogFilter from "@/components/blog/VBlogFilter.vue";
import VBlogPosts from "@/components/blog/VBlogPosts.vue";
import { getTagsWithCountByPosts } from "@/components/blog/utils";
import Layout from "@/layouts/layout.astro";
import { getBlogPosts } from "@/utils/collections/utils";

const blogPosts = await getBlogPosts();
const availableTags = getTagsWithCountByPosts(blogPosts);
---

<Layout className="container gap-32">
	<title slot="head">Blog — Moriz von Langa</title>
	<meta
		slot="head"
		name="description"
		content="A few notes and reminders for myself, usually when I've found a solution to something I was struggling with, discovered a good solution to a channeling problem, or tried something new."
	/>

	<section class="grid max-w-prose-l gap-8">
		<div class="flex items-center gap-4">
			<h1 class="text-4xl leading-snug font-bold">Blog</h1>
			<a
				class="translate-y-1 text-neutral-600 transition-colors hover:text-purple-500"
				href="/blog/rss.xml"
				aria-label="RSS Feed"
				target="_blank">
				<RssIcon
					width="32"
					height="32"
					fill="var(--color-neutral-500)"
				/>
			</a>
		</div>

		<p class="max-w-prose text-neutral-700">
			A few notes and reminders for myself, usually when I've found a
			solution to something I was struggling with or tried something new.
			<br /><br />
			It's just great to have a place to go back to.
		</p>

		<VBlogFilter client:load availableTags={availableTags} />
	</section>

	<VBlogPosts client:load blogPosts={blogPosts} />
</Layout>
