---
import { clsx } from "clsx";
import { twMerge } from "tailwind-merge";

interface Props {
	additionalClasses?: string;
}

const { additionalClasses } = Astro.props;
---

<div
	class={twMerge(
		clsx(
			"prose prose-neutral",
			"prose-a:text-purple-500 prose-a:transition-colors prose-a:hover:text-purple-800",
			"prose-code:rounded prose-code:px-2 prose-code:py-1 prose-code:font-normal",
			"prose-code:bg-neutral-100",
			"prose-code:before:content-none prose-code:after:content-none",
			"prose-code:break-words",
			"[&>pre>code]:bg-transparent [&>pre>code]:p-0",
			"[&>pre>code]:p-0 [&>pre>code]:break-normal",
			"prose-headings:font-normal",
			"prose-headings:scroll-mt-16 prose-strong:scroll-mt-16",
			"prose-h1:text-4xl prose-h2:text-3xl prose-h3:text-2xl prose-h4:text-xl",
			additionalClasses,
		),
	)}>
	<slot />
</div>
